{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "SESSION_STORE": "memory",
    "FPT_TIMEOUT_SECONDS": "3",
    "DEMO_CATALOG_PATH": "backend_py/data/demo_catalog.json"
  }
}