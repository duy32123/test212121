    "Giá gốc": {"key": "original_price", "parser": "price_to_int"},
    "Giá khuyến mãi": {"key": "promotion_price", "parser": "price_to_int"},
    "category_name": "category",
    "onlineSaleOnly": "online_sale_only"
  },
  "effective_price": "promotion_price if > 0 else original_price",
  "stock_status": "unknown (DMX data has no stock — never invented)",
