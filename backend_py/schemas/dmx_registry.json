{
  "_note": "DMX real-data registry (products_detail.json). Top-level fields are shared across all 119 categories; spec maps are per-category, grounded in actual field coverage from products_detail.json. Parsers reused from app/catalog/dmx_registry.py. No product data here — config only.",
  "source": "data/products_detail.json (gitignored, NDA)",
  "version": "2.0.0",
